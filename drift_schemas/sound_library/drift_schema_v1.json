  "fixed_sql": [
    {
      "name": "library_sources",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"library_sources\" (\"id\" TEXT NOT NULL, \"type\" TEXT NOT NULL, \"display_name\" TEXT NOT NULL, \"root_uri\" TEXT NOT NULL, \"permission_bookmark\" BLOB NULL, \"status\" TEXT NOT NULL, \"scan_revision\" INTEGER NOT NULL DEFAULT 0, \"last_scan_started_at\" INTEGER NULL, \"last_scan_completed_at\" INTEGER NULL, \"last_error\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, PRIMARY KEY (\"id\"), UNIQUE (\"type\", \"root_uri\"));"
        }
      ]
    },
    {
      "name": "library_artists",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"library_artists\" (\"id\" TEXT NOT NULL, \"source_id\" TEXT NOT NULL REFERENCES library_sources (id) ON DELETE CASCADE, \"name\" TEXT NOT NULL, \"sort_name\" TEXT NOT NULL, PRIMARY KEY (\"id\"), UNIQUE (\"source_id\", \"sort_name\"));"
        }
      ]
    },
    {
      "name": "library_albums",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"library_albums\" (\"id\" TEXT NOT NULL, \"source_id\" TEXT NOT NULL REFERENCES library_sources (id) ON DELETE CASCADE, \"artist_id\" TEXT NULL REFERENCES library_artists (id) ON DELETE SET NULL, \"title\" TEXT NOT NULL, \"sort_title\" TEXT NOT NULL, \"album_artist\" TEXT NOT NULL, \"year\" INTEGER NULL, \"genre\" TEXT NULL, \"artwork_key\" TEXT NULL, PRIMARY KEY (\"id\"), UNIQUE (\"source_id\", \"album_artist\", \"sort_title\"));"
        }
      ]
    },
    {
      "name": "library_tracks",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"library_tracks\" (\"id\" TEXT NOT NULL, \"source_id\" TEXT NOT NULL REFERENCES library_sources (id) ON DELETE CASCADE, \"album_id\" TEXT NULL REFERENCES library_albums (id) ON DELETE SET NULL, \"artist_id\" TEXT NULL REFERENCES library_artists (id) ON DELETE SET NULL, \"relative_path\" TEXT NOT NULL, \"media_uri\" TEXT NOT NULL, \"title\" TEXT NOT NULL, \"artist_name\" TEXT NOT NULL, \"album_title\" TEXT NOT NULL, \"duration_ms\" INTEGER NOT NULL, \"track_number\" INTEGER NOT NULL DEFAULT 0, \"disc_number\" INTEGER NOT NULL DEFAULT 0, \"year\" INTEGER NULL, \"genre\" TEXT NULL, \"content_type\" TEXT NULL, \"file_size\" INTEGER NULL, \"modified_at\" INTEGER NOT NULL, \"artwork_key\" TEXT NULL, PRIMARY KEY (\"id\"), UNIQUE (\"source_id\", \"relative_path\"));"
        }
      ]
    },
    {
      "name": "library_lyrics",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"library_lyrics\" (\"track_id\" TEXT NOT NULL REFERENCES library_tracks (id) ON DELETE CASCADE, \"sequence\" INTEGER NOT NULL, \"timestamp_ms\" INTEGER NOT NULL, \"text\" TEXT NOT NULL, PRIMARY KEY (\"track_id\", \"sequence\"));"
        }
      ]
    }
  ]
}